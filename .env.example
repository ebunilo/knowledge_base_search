# =============================================================================
#  Knowledge Base Search — environment variables (template)
#  Copy to .env and fill in. NEVER commit .env (it's in .gitignore).
# =============================================================================

# ---------- Query guardrails (API + CLI) ----------
# Block oversized / injection / code-dump input before retriever. Set to false
# to disable (not recommended in production).
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_QUERY_CHARS=4000
GUARDRAILS_MAX_QUERY_LINES=50

# ---------- Deployment profile ----------
APP_PROFILE=demo              # demo | demo-isolated | prod
APP_ENV=dev
APP_REGION=eu-west-1
APP_BIND=127.0.0.1          # set to 0.0.0.0 if exposing directly
APP_PORT=8765
APP_TENANT_INTERNAL_ID=tenant_acme_staff
APP_PUBLIC_COLLECTION=public_v1
APP_PRIVATE_COLLECTION=tenant_acme_staff_private_v1

# ---------- Demo-profile override ----------
# In demo profile, both lanes route to hosted providers.
# MUST be false in prod; startup will refuse otherwise.
DEMO_ALLOW_HOSTED_FOR_SELFHOSTED_LANE=true

# ---------- Hugging Face ----------
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_EMBED_MODE=serverless
HF_EMBED_MODEL_ID=BAAI/bge-m3
HF_RERANK_MODE=serverless
HF_RERANK_MODEL_ID=BAAI/bge-reranker-v2-m3
HF_NLI_MODEL_ID=facebook/bart-large-mnli

# Dedicated endpoints (unset in 'demo', set in 'demo-isolated' or 'prod')
HF_LLM_SELFHOSTED_ENDPOINT_URL=
HF_LLM_SELFHOSTED_MODEL=Qwen/Qwen2.5-14B-Instruct
HF_LLM_SELFHOSTED_KEEP_WARM=false
HF_LLM_SELFHOSTED_COLD_START_TIMEOUT_S=120

# ---------- Qwen API ----------
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxx
# DashScope has two regions with different model catalogs:
#   - China: https://dashscope.aliyuncs.com/compatible-mode/v1      (qwen2.5-*-instruct)
#   - Intl:  https://dashscope-intl.aliyuncs.com/compatible-mode/v1 (qwen-turbo/plus/max)
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_SMALL=qwen-turbo
QWEN_MODEL_MID=qwen-plus
QWEN_MODEL_LARGE=qwen-max

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
OPENAI_MODEL_GENERATOR=gpt-4o-mini

# ---------- Lane routing ----------
HOSTED_LANE_PRIORITY=openai:gpt-4o-mini,qwen:qwen2.5-32b-instruct
SELFHOSTED_LANE_PRIORITY=openai:gpt-4o-mini,qwen:qwen2.5-32b-instruct

# ---------- Ingestion controls ----------
BM25_BACKEND=rank_bm25
INGESTION_ENRICH_LIMIT=500
INGESTION_ENRICH_STRATEGY=sample_first

# ---------- Warm-up ----------
WARMUP_ON_APP_START=false
WARMUP_CRON_WINDOW=

# ---------- Observability ----------
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxx
LANGSMITH_PROJECT=acme-kb-search
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
#  Local data plane (docker-compose)
#  These are also read by docker-compose to configure the containers.
#  Generate strong values with:  openssl rand -hex 24
# =============================================================================

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=CHANGE_ME_qdrant_api_key_32chars

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kb
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_24chars
POSTGRES_DB=kb
POSTGRES_URL=postgresql://kb:CHANGE_ME_postgres_password_24chars@localhost:5432/kb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_24chars
REDIS_URL=redis://default:CHANGE_ME_redis_password_24chars@localhost:6379/0

# Local TEI (only if you run `docker compose --profile ingestion up`)
TEI_URL=http://localhost:8080
